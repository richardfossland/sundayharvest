# Copy to .env.local and fill in. Uses the SHARED SundaySuite Supabase project
# (same project as SundayChess/Market/Turnering/Quiz) — SundayHarvest lives in
# its own `harvest` Postgres schema. After running supabase/migrations the
# `harvest` schema MUST be added under Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_APP_URL=https://harvest.sundaysuite.app
