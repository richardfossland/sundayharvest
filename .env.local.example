# Copy to .env.local and fill in. Uses the SHARED SundaySuite Supabase project
# (same project as SundayChess/Market/Turnering/Quiz) — SundayHarvest lives in
# its own `harvest` Postgres schema. After running supabase/migrations the
# `harvest` schema MUST be added under Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_APP_URL=https://harvest.sundaysuite.app

# ---------------------------------------------------------------------------
# OPTIONAL — Sunday Account HOST sign-in (SSO). Players/joiners/displays stay
# 100% code-based; this is ONLY for the vert/host dashboard ("Øktene mine").
# Leave all of these UNSET to ship harvest exactly as before (no host login).
#
# The auth client points at the shared Sunday Account ISSUER project (the same
# project SundayInfo's NEXT_PUBLIC_SUPABASE_URL/ANON_KEY point at) — this is
# SEPARATE from the game DATA project above (NEXT_PUBLIC_SUPABASE_URL).
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-ISSUER-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=YOUR-ISSUER-ANON-KEY

# Share the sb-* session cookie across *.sundaysuite.app (PRODUCTION ONLY —
# leave UNSET in local dev so cookies work on localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Allow-list of host emails (comma / space / semicolon separated). Only these
# Sunday accounts may open the host dashboard + delete økter. Empty/unset =
# nobody is a host (fail-closed). Server-side ONLY — never NEXT_PUBLIC_.
HARVEST_ADMIN_EMAILS=you@example.com,co-host@example.com

# OPTIONAL — service-role key for the game DATA project. NOT required: the
# dashboard reads sessions via open RLS SELECT and deletes via a SECURITY
# DEFINER RPC granted to anon. Set it only for defence-in-depth as a Worker
# secret:  wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OPTIONAL — AI debrief facilitator (/api/debrief). Server-side ONLY: in
# production this is a Cloudflare Worker SECRET, never a NEXT_PUBLIC_ var, never
# in the client bundle. Set it with:  wrangler secret put ANTHROPIC_API_KEY
# Without a key the EndScreen keeps its existing static debrief (no regression).
# ANTHROPIC_API_KEY=sk-ant-...
