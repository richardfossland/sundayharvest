# Copy to .env.local and fill in. Uses the SHARED SundaySuite Supabase project
# (same project as SundayChess/Market/Turnering/Quiz) — SundayHarvest lives in
# its own `harvest` Postgres schema. After running supabase/migrations the
# `harvest` schema MUST be added under Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_APP_URL=https://harvest.sundaysuite.app

# OPTIONAL — AI debrief facilitator (/api/debrief). Server-side ONLY: in
# production this is a Cloudflare Worker SECRET, never a NEXT_PUBLIC_ var, never
# in the client bundle. Set it with:  wrangler secret put ANTHROPIC_API_KEY
# Without a key the EndScreen keeps its existing static debrief (no regression).
# ANTHROPIC_API_KEY=sk-ant-...
